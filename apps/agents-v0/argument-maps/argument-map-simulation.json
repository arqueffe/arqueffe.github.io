{
  "contentionNodeId": "mnode-1",
  "nodes": [
    {
      "id": "mnode-1",
      "kind": "main-conclusion",
      "text": "We are currently living in a computer-generated simulation rather than a base physical reality.",
      "role": "Moderator",
      "round": 1,
      "confidence": 1,
      "createdAt": 1777743026810
    },
    {
      "id": "mnode-2",
      "kind": "premise",
      "text": "If advanced civilizations could create simulations indistinguishable from reality, it is statistically more likely that we are in a simulation than in base reality.",
      "role": "Advocate",
      "round": 1,
      "confidence": 1,
      "createdAt": 1777743027601
    },
    {
      "id": "mnode-3",
      "kind": "objection",
      "text": "There is currently no empirical evidence to suggest that our reality is a simulation rather than base reality.",
      "role": "Sophist",
      "round": 1,
      "confidence": 1,
      "createdAt": 1777743029585
    },
    {
      "id": "mnode-4",
      "kind": "objection",
      "text": "The assumption that simulated realities would vastly outnumber base realities ignores potential limitations on computational resources and ethical constraints of advanced civilizations.",
      "role": "Critic",
      "round": 1,
      "confidence": 1,
      "createdAt": 1777743031313
    },
    {
      "id": "mnode-5",
      "kind": "premise",
      "text": "The continued advancement of virtual reality and artificial intelligence technologies demonstrates that creating highly realistic simulated experiences is becoming increasingly feasible.",
      "role": "Advocate",
      "round": 2,
      "confidence": 1,
      "createdAt": 1777743032701
    },
    {
      "id": "mnode-6",
      "kind": "objection",
      "text": "Technological feasibility of creating realistic simulations does not imply that such simulations are actually being created or that we are inside one.",
      "role": "Critic",
      "round": 2,
      "confidence": 1,
      "createdAt": 1777743034289
    },
    {
      "id": "mnode-7",
      "kind": "rebuttal",
      "text": "The lack of empirical evidence for a simulation hypothesis does not disprove its possibility, as limitations in detection methods could prevent us from perceiving the underlying nature of reality.",
      "role": "Sophist",
      "round": 2,
      "confidence": 1,
      "createdAt": 1777743037349
    }
  ],
